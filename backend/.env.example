# ============================================================
# !! PRODUCTION DEPLOYMENT !!
# ============================================================
# Before deploying to production:
#   1. Set ENVIRONMENT=production (below)
#   2. Set JWT_SECRET to a strong random string (>= 32 chars)
#   3. Set DEV_RETURN_RESET_TOKEN=0 (or remove it entirely)
#
# The app will REFUSE TO START if ENVIRONMENT=production and
# JWT_SECRET is empty, a known placeholder, or shorter than 32 chars.
#
# Generate a secret with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
#
# NEVER copy this file to .env without editing ENVIRONMENT and JWT_SECRET.
# ============================================================

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/scholarshipright
REDIS_URL=redis://localhost:6379

# App
FRONTEND_URL=http://localhost:3000

# JWT signing secret. Must be >= 32 random characters in production.
JWT_SECRET=change-me-to-a-random-secret-of-at-least-32-chars

# Runtime environment: "development" (default) or "production".
# Controls startup validation of JWT_SECRET and other prod-only safety checks.
ENVIRONMENT=development

# Dev-only: include the raw password-reset token in the
# /api/auth/forgot-password response. Set to "0" or unset in production.
DEV_RETURN_RESET_TOKEN=1

# Unified LLM provider (OpenAI-compatible endpoint).
# Used by BOTH the resume analyzer and the Scholara agent.
# To switch providers, change only these three values.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# Legacy variables (optional): if LLM_* are not set, the app falls back to
# OPENAI_* for the resume analyzer and AGENT_* for the chat agent.
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# AGENT_BASE_URL=https://api.openai.com/v1
# AGENT_API_KEY=sk-...
# AGENT_MODEL=gpt-4o-mini

# Google OAuth (optional). Leave empty to disable Google sign-in.
# Get credentials from https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:8000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SERVER_URL=http://localhost:8000

# MCP OAuth (AI agent connections via Claude.ai, ChatGPT, etc.)
# Set MCP_OAUTH_ENABLED=1 to allow AI agents to connect.
# Only admin/staff users can authenticate — they see your custom login form.
# MCP_OAUTH_SERVER_URL must be your public URL (ngrok domain or production).
# JWT_SECRET (above) is used to sign tokens — no external auth provider needed.
MCP_OAUTH_ENABLED=1
MCP_OAUTH_SERVER_URL=https://your-ngrok-or-production-url
# MCP_OAUTH_AUDIENCE and MCP_OAUTH_SCOPES_SUPPORTED are optional (have defaults).
# MCP_OAUTH_AUDIENCE defaults to MCP_OAUTH_SERVER_URL.
# MCP_OAUTH_SCOPES_SUPPORTED defaults to "scholarships:read,scholarships:write".

# JWKS fallback (optional — only if you need to validate tokens from an external auth provider).
# Not needed for the self-issued OAuth flow above.
# MCP_OAUTH_ISSUER=https://your-auth-provider.com
# MCP_OAUTH_JWKS_URL=https://your-auth-provider.com/.well-known/jwks.json
