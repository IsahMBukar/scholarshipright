# Frontend → Backend URL used by the browser.
# In production:
#   - Must point at the publicly reachable backend (no `localhost`).
#   - Must include the `http://` or `https://` scheme.
#   - Must NOT have a trailing slash or `/api` suffix.
#     The `API_URL` consumers in src/services/api.ts and the auth pages
#     build /api/* paths on top of this base.
#
# Examples:
#   NEXT_PUBLIC_API_URL=https://api.scholarshipright.com
#   NEXT_PUBLIC_API_URL=http://localhost:8000      (local dev)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Show "Quick dev login" button on the login page.
# Set to "1" in local dev. Omit or set to anything else in production.
# The backend already returns 404 for /api/auth/dev-login in production,
# but this hides the button from the UI entirely.
NEXT_PUBLIC_ENABLE_DEV_LOGIN=1
